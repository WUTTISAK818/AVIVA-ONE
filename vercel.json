{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_TARGET": "one"
  },
  "crons": [
    {
      "path": "/api/cron/report-reminder",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/report-digest-notify",
      "schedule": "30 12 * * *"
    }
  ]
}
